# Database Configuration
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_db
DB_PORT=5432
DATABASE_URL=postgresql://your_user:your_password@db:5432/your_db

# Security
JWT_SECRET_KEY=generate-a-safe-secret-key

# Proxy Configuration (for corporate networks - optional)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=db,api,frontend,redis,localhost,127.0.0.1

# Scheduling
REDIS_PORT=6379

# Frontend / API
API_PORT=5000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NODE_ENV=development
FLASK_DEBUG=1
